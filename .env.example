# Environment file for deploy-forgejo-standalone.
# Copy this file to .env and edit it before running scripts/deploy.sh.
# The deploy script installs it to the persistent config path.

# Project/container naming prefix.
COMPOSE_PROJECT_NAME=forgejo

# Container image.
FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:12

# Container user used by Forgejo image.
# The official container commonly uses UID/GID 1000.
FORGEJO_UID=1000
FORGEJO_GID=1000

# Public service name used by Forgejo.
# Use a hostname or FQDN that clients will use to access this service.
FORGEJO_DOMAIN=localhost

# HTTP listener published on the host.
FORGEJO_HTTP_HOST=127.0.0.1
FORGEJO_HTTP_PORT=3000

# SSH listener published on the host for Git over SSH.
FORGEJO_SSH_HOST=127.0.0.1
FORGEJO_SSH_PORT=2222

# Application URL visible to users.
# Keep this consistent with the HTTP host/port used by clients.
FORGEJO_ROOT_URL=http://localhost:3000/

# Host-side data directory.
# For rootless deployment, keep runtime data outside the Git checkout.
# Leave unset to use the XDG data path resolved by runtime scripts.
# If set, use a literal absolute path. Do not use ${HOME} or ~ here,
# because compose implementations may parse .env differently.
# FORGEJO_DATA_DIR=/home/your-user/.local/share/forgejo

# Application name shown in the UI.
FORGEJO_APP_NAME=Forgejo
